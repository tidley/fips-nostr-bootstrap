    "test:transport:nostr": "node scripts/udp-transport-via-nostr.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.6.3",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "nostr-tools": "^2.23.3"
  }
}
